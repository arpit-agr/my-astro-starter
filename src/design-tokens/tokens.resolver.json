{
	"version": "2025.10",
	"resolutionOrder": [
		{
			"type": "set",
			"name": "base",
			"sources": [
				{ "$ref": "./base/palette.json" },
				{ "$ref": "./base/borders.json" },
				{ "$ref": "./base/containers.json" },
				{ "$ref": "./base/corners.json" },
				{ "$ref": "./base/elevation.json" },
				{ "$ref": "./base/motion.json" },
				{ "$ref": "./base/shadows.json" },
				{ "$ref": "./base/size.json" },
				{ "$ref": "./base/space.json" },
				{ "$ref": "./base/font.json" }
			]
		},
		{
			"type": "set",
			"name": "semantics",
			"sources": [
				{ "$ref": "./semantics/colors.json" },
				{ "$ref": "./semantics/cube.json" },
				{ "$ref": "./semantics/focus.json" }
			]
		},
		{
			"type": "set",
			"name": "components",
			"sources": [
				{ "$ref": "./components/button.json" },
				{ "$ref": "./components/form-controls.json" },
				{ "$ref": "./components/panels.json" }
			]
		},
		{
			"type": "modifier",
			"name": "theme",
			"default": "light",
			"contexts": {
				"light": [],
				"dark": [{ "$ref": "./semantics/dark.json" }]
			}
		}
	]
}
