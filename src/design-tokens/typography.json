{
	"font": {
		"$type": "fontFamily",
		"body": {
			"$value": "{font.sans}"
		},
		"heading": {
			"$value": "{font.sans}"
		},
		"sans": {
			"$value": [
				"-apple-system",
				"BlinkMacSystemFont",
				"Segoe UI",
				"Roboto",
				"Helvetica Neue",
				"Arial",
				"sans-serif"
			]
		},
		"mono": {
			"$value": [
				"SFMono-Regular",
				"Consolas",
				"Liberation Mono",
				"Menlo",
				"monospace"
			]
		},
		"serif": {
			"$value": ["Georgia", "Cambria", "Times New Roman", "Times", "serif"]
		},
		"weight": {
			"$type": "fontWeight",
			"normal": { "$value": 400 },
			"medium": { "$value": 500 },
			"semibold": { "$value": 600 },
			"bold": { "$value": 700 }
		}
	},
	"leading": {
		"$type": "number",
		"title": {
			"$value": "{leading.tight}"
		},
		"none": { "$value": 1.05 },
		"tight": { "$value": 1.25 },
		"normal": { "$value": 1.5 },
		"relaxed": { "$value": 1.75 }
	},
	"tracking": {
		"$type": "dimension",
		"tight": { "$value": { "value": -0.025, "unit": "rem" } },
		"normal": { "$value": { "value": 0, "unit": "rem" } },
		"wide": { "$value": { "value": 0.025, "unit": "rem" } }
	}
}
