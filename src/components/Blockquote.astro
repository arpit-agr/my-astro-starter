<figure class="flow">
	<blockquote>
		<slot />
	</blockquote>
	{
		Astro.slots.has('author') && (
			<figcaption class="flow-space-3xs-2xs">
				<slot name="author" />
				{Astro.slots.has('citation') && (
					<Fragment>
						-
						<cite>
							<slot name="citation" />
						</cite>
					</Fragment>
				)}
			</figcaption>
		)
	}
</figure>
